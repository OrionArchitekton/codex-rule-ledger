    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
